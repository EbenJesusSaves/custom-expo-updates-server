{
  "name": "expo-updates-client",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "publish": "node scripts/publish-update.js",
    "publish:remote": "EXPO_UPDATES_SERVER_URL=https://your-server-domain.com node scripts/publish-update.js",
    "config:local": "node scripts/set-server-url.js local",
    "config:emulator": "node scripts/set-server-url.js emulator",
    "config:device": "node scripts/set-server-url.js device",
    "config:production": "node scripts/set-server-url.js production",
    "build:android": "npm run config:emulator && expo run:android --variant release",
    "build:ios": "npm run config:local && expo run:ios --configuration Release"
  },
  "dependencies": {
    "@expo/config": "^10.0.0",
    "expo": "~52.0.47",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.4",
    "form-data": "^4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  },
  "private": true
}
